# Local: copy to `.env.local`. Production: set the same names in InsForge (or Vercel) env UI.
# Deployment checklist: `docs/deployment-insforge.md`

# --- Supabase (public; RLS still applies) ---
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only (never NEXT_PUBLIC_) ---
# https://console.groq.com/keys
GROQ_API_KEY=
# https://console.cloud.google.com/google/maps-apis
GOOGLE_PLACES_API_KEY=
# Optional — enrichment skipped if empty
# https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=

# --- InsForge (feedback API); base URL must NOT end with `/` ---
# https://docs.insforge.dev/mcp-setup
NEXT_PUBLIC_INSFORGE_BASE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
