# Copy to .env.local and fill from Supabase → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Groq (server only — never use NEXT_PUBLIC_ for API keys)
# https://console.groq.com/keys
GROQ_API_KEY=

# Google Places — specialist search (server only)
# https://console.cloud.google.com/google/maps-apis
GOOGLE_PLACES_API_KEY=

# Tinyfish — optional clinic website enrichment (server only)
# https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=
