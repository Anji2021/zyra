# Local: copy to `.env.local`. Production: set the same names in your hosting env UI.

# --- Supabase (public; RLS still applies) ---
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com
CRON_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# --- Server-only (never NEXT_PUBLIC_) ---
# https://console.groq.com/keys — DoctorMatch AI, CarePrep script, and insight-summary refinement (server-only)
GROQ_API_KEY=
# Optional (default in code: llama-3.1-8b-instant)
GROQ_MODEL=
# Seedance / BytePlus ModelArk video generation (CarePrep video). Server-only — tried first when SEEDANCE_API_KEY is set.
# https://docs.byteplus.com/en/docs/ModelArk/1298459
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com
SEEDANCE_GENERATE_PATH=/api/v3/contents/generations/tasks
SEEDANCE_MODEL_ID=dreamina-seedance-2-0-260128
# Legacy: base ending in /api/v3 — code appends /contents/generations/tasks if SEEDANCE_BASE_URL is unset
SEEDANCE_API_BASE_URL=
SEEDANCE_MODEL=
SEEDANCE_DURATION=4
SEEDANCE_RATIO=16:9
SEEDANCE_DURATION_SECONDS=
# ImaRouter — CarePrep video fallback when Seedance fails or key unset
IMAROUTER_API_KEY=
IMAROUTER_BASE_URL=https://api.imarouter.com
# Default in code: happyhorse-1.0-t2v (text-to-video)
IMAROUTER_VIDEO_MODEL=
# https://console.cloud.google.com/google/maps-apis
GOOGLE_PLACES_API_KEY=

# --- Butterbase (optional hackathon demo logging — CarePrep only; does not replace Supabase) ---
# Data API: POST {BUTTERBASE_BASE_URL}/{BUTTERBASE_TABLE}. Base URL must include /v1/{app_id} (no trailing slash).
# https://docs.butterbase.ai/api-reference/data-api/
BUTTERBASE_API_KEY=
BUTTERBASE_BASE_URL=
# Optional table name (default: care_prep_demo). Create matching columns in Butterbase or relax schema as needed.
# BUTTERBASE_TABLE=care_prep_demo

